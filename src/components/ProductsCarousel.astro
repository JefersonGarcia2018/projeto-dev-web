---
// ProductsCarousel component
---
<section class="secao produtos-home">
  <div class="container">

    <div class="flex-center txt-categorias mb-2">
      <div class="grid-8 grid-m-7 grid-s-12">
        <h3 class="subtitulo left top-tit primary" data-aos="fade-up">Portfólio</h3>
        <h2 class="titulo left mb-0" data-aos="fade-up">Soluções Premium de Alto Impacto</h2>
      </div>

      <div class="hide-mobile grid-4 grid-m-5 grid-s-12">
        <div class="btn-container right mt-0">
          <button class="btn btn-primario outline">
            <span class="blob-effect">
              <span class="blob-btn__inner">
                <span class="blob-btn__blobs">
                  <span class="blob-btn__blob"></span>
                  <span class="blob-btn__blob"></span>
                  <span class="blob-btn__blob"></span>
                  <span class="blob-btn__blob"></span>
                </span>
              </span>
            </span>Ver mais projetos
          </button>
        </div>
      </div>
    </div>

    <!-- CARROSSEL -->
    <div class="grid-12" data-aos="fade-up">
      <div class="splide carousel carousel-arrows-zoom carrossel-produtos" id="splide04">
        <div class="splide__track" id="splide04-track">
          <div class="splide__list" id="splide04-list">

            <!-- Produto 1 -->
            <div class="splide__slide" id="splide04-slide01">
              <div class="bloco-produto">
                <a href="#">
                  <figure class="bloco-produto-foto">
                    <img class="shimmer lazyload" data-src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=400" src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=400" alt="Portal de E-commerce SaaS" />
                  </figure>
                </a>
                <div class="bloco-produto-infos">
                  <a href="#">
                    <div class="bloco-produto-categoria">Next.js & Stripe</div>
                    <div class="bloco-produto-titulo">Portal de E-commerce SaaS</div>
                  </a>
                </div>
              </div>
            </div>

            <!-- Produto 2 -->
            <div class="splide__slide" id="splide04-slide02">
              <div class="bloco-produto">
                <a href="#">
                  <figure class="bloco-produto-foto">
                    <img class="shimmer lazyload" data-src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=400" src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=400" alt="Dashboard Corporativo Financeiro" />
                  </figure>
                </a>
                <div class="bloco-produto-infos">
                  <a href="#">
                    <div class="bloco-produto-categoria">React & Chart.js</div>
                    <div class="bloco-produto-titulo">Dashboard Corporativo Financeiro</div>
                  </a>
                </div>
              </div>
            </div>

            <!-- Produto 3 -->
            <div class="splide__slide" id="splide04-slide03">
              <div class="bloco-produto">
                <a href="#">
                  <figure class="bloco-produto-foto">
                    <img class="shimmer lazyload" data-src="https://images.unsplash.com/photo-1507238691740-187a5b1d37b8?q=80&w=400" src="https://images.unsplash.com/photo-1507238691740-187a5b1d37b8?q=80&w=400" alt="Landing Page de Alta Conversão" />
                  </figure>
                </a>
                <div class="bloco-produto-infos">
                  <a href="#">
                    <div class="bloco-produto-categoria">Astro & Tailwind</div>
