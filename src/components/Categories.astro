---
// Categories component
---
<section class="secao grey categorias-home">
  <div class="container">
    <h3 class="subtitulo top-tit primary">Linha de Produtos</h3>
    <h2 class="titulo">Desde 1991, Criando Ambientes que Encantam</h2>
    <div class="flex-center mb-2">
      <h4 class="grid-8 grid-s-12 grid-m-10 texto center">
        <p>Nossa linha de produtos em madeira combina tradição, design e tecnologia para criar portas, painéis, revestimentos e móveis que transformam qualquer ambiente com elegância e durabilidade.</p>
      </h4>
    </div>

    <!-- CARROSSEL -->
    <div class="grid-12" data-aos="fade-up" data-aos-offset="0">
      <div class="splide carousel carousel-arrows-zoom carrossel-servicos" id="splide03">
        <div class="splide__track" id="splide03-track">
          <div class="splide__list" id="splide03-list">

            <!-- Categoria 1 -->
            <div class="splide__slide" id="splide03-slide01">
              <a href="/produtos/portas-e-janelas" class="servico">
                <div class="servico-img">
                  <img class="shimmer lazyload" data-src="/assets/88fa9363ecb642fb5e9700cc33ae8b9f.jpg" src="/assets/88fa9363ecb642fb5e9700cc33ae8b9f.jpg" width="265px" height="331px" alt="Portas e Janelas" />
                </div>
                <div class="servico-infos">
                  <div class="servico-tit">Portas e Janelas</div>
                  <div class="servico-txt">Beleza e resistência em madeira maciça para seus espaços externos.</div>
                  <div class="servico-btn"><button class="btn btn-primario"></button></div>
                </div>
              </a>
            </div>
            
            <!-- Categoria 2 -->
            <div class="splide__slide" id="splide03-slide02">
              <a href="/produtos/portas-internas" class="servico">
                <div class="servico-img">
                  <img class="shimmer lazyload" data-src="/assets/477eee2309ef70f31c0f87ec14a8d326.jpg" src="/assets/477eee2309ef70f31c0f87ec14a8d326.jpg" width="265px" height="331px" alt="Portas Internas" />
                </div>
                <div class="servico-infos">
                  <div class="servico-tit">Portas Internas</div>
                  <div class="servico-txt">Portas fabricadas em Lacca, Lâmina de madeira e opções em madeira maciça.</div>
                  <div class="servico-btn"><button class="btn btn-primario"></button></div>
                </div>
              </a>
            </div>

            <!-- Categoria 3 -->
            <div class="splide__slide" id="splide03-slide03">
              <a href="/produtos/moveis-de-jardim" class="servico">
                <div class="servico-img">
                  <img class="shimmer lazyload" data-src="/assets/d7d9ea41ab78452248a3d8def519cacf.png" src="/assets/d7d9ea41ab78452248a3d8def519cacf.png" width="265px" height="331px" alt="Móveis de Jardim" />
                </div>
                <div class="servico-infos">
                  <div class="servico-tit">Móveis de Jardim</div>
                  <div class="servico-txt">Soluções em madeira para viver o exterior com estilo</div>
                  <div class="servico-btn"><button class="btn btn-primario"></button></div>
                </div>
              </a>
            </div>

          </div>
        </div>
      </div>
    </div>
    <!-- //CARROSSEL -->

  </div>
</section>
