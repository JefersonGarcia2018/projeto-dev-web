---
// About component
---
<section class="secao home-sobre overflow-hidden">
  <div class="container">
    <div class="home-sobre-content">

      <!-- Textos -->
      <div class="grid-6 grid-s-12 home-sobre-infos" data-aos="fade-right" data-aos-offset="0">

        <h3 class="subtitulo top-tit left">Quem Somos</h3>
        <h2 class="titulo left">Jeferson Dev Full Stack</h2>

        <!-- Imagem mobile -->
        <span class="load-img-mobile" data-img="sobre-home"></span>

        <div class="texto">
          <p>De projetos pessoais a soluções corporativas de grande porte, minha trajetória na programação é pautada por inovação, boas práticas e alta performance.</p>
          <p>Com ampla experiência em desenvolvimento frontend e backend, crio sistemas web robustos, sites premium e aplicações em nuvem escaláveis e seguras.</p>
        </div>

        <div class="btn-container left">
          <a href="/quem-somos" class="btn btn-primario outline">
            <span class="blob-effect">
              <span class="blob-btn__inner">
                <span class="blob-btn__blobs">
                  <span class="blob-btn__blob"></span>
                  <span class="blob-btn__blob"></span>
                  <span class="blob-btn__blob"></span>
                  <span class="blob-btn__blob"></span>
                </span>
              </span>
            </span>Saiba Mais
          </a>
          <a href="tel:67999169556" class="contact-header">
            <div class="icon-tel"><i class="fas fa-phone fa-flip-horizontal"></i></div>
            <span><div class="tel-number">(67) 99916-9556</div>Fale Conosco!</span>
          </a>
        </div>

        <ul class="contadores-lista">
          <!-- Contador 1 -->
          <li class="grid-4 grid-m-6 grid-s-12 contador-wrp" data-aos="fade-up">
            <div class="contador-item">
              <div class="contador-num-wrp">
                <div class="contador-prefix">+</div>
                <div class="contador-num" data-count="8">8</div>
                <div class="contador-sufix">Anos</div>
              </div>
              <div class="contador-titulo">Experiência em TI</div>
            </div>
          </li>
          
          <!-- Contador 2 -->
          <li class="grid-4 grid-m-6 grid-s-12 contador-wrp" data-aos="fade-up">
            <div class="contador-item">
              <div class="contador-num-wrp">
                <div class="contador-prefix">+</div>
                <div class="contador-num" data-count="50">50</div>
                <div class="contador-sufix">Projetos</div>
              </div>
              <div class="contador-titulo">Projetos Entregues</div>
            </div>
          </li>

          <!-- Contador 3 -->
          <li class="grid-4 grid-m-6 grid-s-12 contador-wrp" data-aos="fade-up">
            <div class="contador-item">
              <div class="contador-num-wrp">
                <div class="contador-prefix">+</div>
                <div class="contador-num" data-count="100">100</div>
                <div class="contador-sufix">%</div>
              </div>
              <div class="contador-titulo">Satisfação Garantida</div>
            </div>
          </li>
        </ul>

      </div>
      <!-- //Textos -->

      <!-- Foto -->
      <div class="grid-6 grid-s-12 home-sobre-foto" data-id-img="sobre-home">    
        <figure class="img-1" data-aos="fade-down" data-aos-offset="0">
          <img class="shimmer lazyload" data-src="https://images.unsplash.com/photo-1542831371-29b0f74f9713?q=80&w=600" src="https://images.unsplash.com/photo-1542831371-29b0f74f9713?q=80&w=600" width="580px" height="406px" alt="Tecnologia" />
        </figure>
        <figure class="img-2" data-aos="fade-up" data-aos-offset="0">
          <img class="shimmer lazyload" data-src="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=600" src="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=600" width="580px" height="406px" alt="Desenvolvimento" />
        </figure>
      </div>
      <!-- //Foto -->

    </div>
  </div>
</section>
