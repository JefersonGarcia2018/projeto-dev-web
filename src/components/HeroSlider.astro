---
// HeroSlider component
---
<section class="slide-home">
  <div class="splide carousel-slide carousel-arrows-fade carousel-controls-white" data-slide-interval="5000" data-slide-progress="false" id="splide01">
    <div class="splide__track" id="splide01-track">
      <div class="splide__list" id="splide01-list">
        <!-- Slide 1 -->
        <div class="splide__slide" id="splide01-slide01">
          <a href="#" class="carousel-slide-item carousel-slide-bg">
            <!-- Background Desktop -->
            <div class="hide-mobile carousel-slide-bg-img" style="background-image: url('/assets/d64f4ea92b84ca3a17e5376d340c44bf.png'); background-size: cover; background-position: center;"></div>
            <!-- Background Mobile -->
            <div class="hide-desktop hide-tablet carousel-slide-bg-img" style="background-image: url('/assets/d64f4ea92b84ca3a17e5376d340c44bf.png'); background-size: cover; background-position: center;"></div>
            
            <!-- Conteúdo -->
            <div class="carousel-slide-overlay center">
              <div class="container carousel-slide-content">
                <div class="subtitulo top-tit primary carousel-slide-subtit fade-up" data-slide-animation="fade-up" data-slide-animation-delay="200">Desenvolvimento de Software de Alto Padrão</div>
                <div class="titulo carousel-slide-tit fade-up" data-slide-animation="fade-up" data-slide-animation-delay="200" style="font-weight: 700; color: #fff;">
                  Eleve o Padrão da Sua Empresa com <br /> <b id="typed" data-itens="Sistemas Web Robustos, Landing Pages Rápidas, E-commerces Otimizados, Código Limpo & Seguro, Design Premium & Responsivo" style="color: #f29718;">Sistemas Web Robustos</b>
                </div>
              </div>
            </div>
            
            <div class="bg-mouse">
              <img src="/assets/scroll.png" alt="Scroll" />
              <div class="field">
                <div class="mouse"></div>
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  // Inicialização do Typed.js após o carregamento da biblioteca
  document.addEventListener('DOMContentLoaded', function() {
    var typedEl = document.querySelector('#typed');
    if (typedEl && typeof Typed !== 'undefined') {
      var itens = typedEl.dataset.itens.split(",");
      new Typed('#typed', {
        strings: itens,
        typeSpeed: 65,
        backDelay: 2000,
        backSpeed: 15,
        smartBackspace: false,
        loop: true
      });
    }
  });
</script>
