---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Modals from '../components/Modals.astro';
---

<Layout title="Serviços - Jeferson Dev Full Stack">
  <Header />

  <!-- BANNER -->
  <section class="pag-banner" style="background-image: url('https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=2000');">
    <div class="mascara"></div>
    <div class="container">
      <div class="grid-12 content" data-aos="fade-up">
        <h3 class="subtitulo top-tit primary">Serviços</h3>
        <h1 class="titulo" style="font-weight: 700; color: #fff;">Design Premium, Performance e Tecnologia sob Medida</h1>
        <ul class="breadcrumb">
          <li><a href="/">Home</a></li>
          <li><a href="#">Serviços</a></li>
        </ul>
      </div>
    </div>
  </section>
  <!-- //BANNER -->

  <!-- PÁGINA -->
  <section class="secao secao-pag grey">
    <div class="container">

      <div class="flex-center list-products-page">

        <!-- Categoria 1: Sistemas & Apps Web -->
        <a href="/produtos/portas-e-janelas" class="grid-4 grid-m-6 grid-s-12 servico">
          <div class="servico-img">
            <img class="shimmer lazyload" data-src="/assets/88fa9363ecb642fb5e9700cc33ae8b9f.jpg" src="/assets/88fa9363ecb642fb5e9700cc33ae8b9f.jpg" width="265px" height="331px" alt="Sistemas & Apps Web" />
          </div>
          <div class="servico-infos">
            <div class="servico-tit">Sistemas & Apps Web</div>
            <div class="servico-txt">Desenvolvimento de portais full stack sob medida, dashboards interativos e automações.</div>
            <div class="servico-btn"><button class="btn btn-primario"></button></div>
          </div>
        </a>

        <!-- Categoria 2: Websites & Landing Pages -->
        <a href="/produtos/portas-internas" class="grid-4 grid-m-6 grid-s-12 servico">
          <div class="servico-img">
            <img class="shimmer lazyload" data-src="/assets/477eee2309ef70f31c0f87ec14a8d326.jpg" src="/assets/477eee2309ef70f31c0f87ec14a8d326.jpg" width="265px" height="331px" alt="Websites & Landing Pages" />
          </div>
          <div class="servico-infos">
            <div class="servico-tit">Websites & Landing Pages</div>
            <div class="servico-txt">Sites institucionais e landing pages de alta conversão, responsivos e otimizados para SEO.</div>
            <div class="servico-btn"><button class="btn btn-primario"></button></div>
          </div>
        </a>

        <!-- Categoria 3: E-commerce & Lojas Virtuais -->
        <a href="/produtos/moveis-de-jardim" class="grid-4 grid-m-6 grid-s-12 servico">
          <div class="servico-img">
            <img class="shimmer lazyload" data-src="/assets/d7d9ea41ab78452248a3d8def519cacf.png" src="/assets/d7d9ea41ab78452248a3d8def519cacf.png" width="265px" height="331px" alt="E-commerce & Lojas Virtuais" />
          </div>
          <div class="servico-infos">
            <div class="servico-tit">E-commerce & Lojas Virtuais</div>
            <div class="servico-txt">Lojas virtuais robustas, seguras, integradas com meios de pagamento e focadas em vendas.</div>
            <div class="servico-btn"><button class="btn btn-primario"></button></div>
          </div>
        </a>

      </div>

    </div>
  </section>
  <!-- //PÁGINA -->

  <Footer />
  <Modals />
</Layout>
