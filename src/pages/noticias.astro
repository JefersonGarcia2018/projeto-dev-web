---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Modals from '../components/Modals.astro';
---

<Layout title="Novidades - Esel">
  <Header />

  <!-- BANNER -->
  <section class="pag-banner" style="background-image: url('https://www.esel.com.br/uploads/paginas/18/thumb-2000-400/167c62fdeb960da190a25d2fa2abd544.png');">
    <div class="mascara"></div>
    <div class="container">
      <div class="grid-12 content" data-aos="fade-up">
        <h2 class="top-tit primary subtitulo">Novidades</h2>
        <h1 class="titulo" style="font-weight: 700; color: #fff;">Últimas Novidades</h1>
        <ul class="breadcrumb">
          <li><a href="/">Home</a></li>
          <li><a href="#">Novidades</a></li>
        </ul>
      </div>
    </div>
  </section>
  <!-- //BANNER -->

  <!-- PÁGINA -->
  <section class="secao secao-pag">
    <div class="container">
      
      <!-- FILTROS CATEGORIAS MOBILE -->
      <div class="grid-12 produtos-categorias-select hide-desktop" data-aos="fade-up">
        <div class="campo-container">
          <select id="prod-cat-mb" class="campo">
            <option value="/noticias">Todos posts</option>
            <option value="#">Esquadrias de Madeira</option>
            <option value="#">Dicas</option>
          </select>
          <i class="arrow"></i>
        </div>					
      </div>
      
      <!-- LISTA -->
      <div class="lista-posts">
        
        <!-- POSTS GRID (ESQUERDA) -->
        <div class="grid-8 grid-m-12 grid-s-12 lista-post-blog">

          <!-- Post 1 -->
          <a href="/post/esquadrias-de-madeira-macica" class="grid-6 grid-m-6 grid-s-12 blog-p">           
            <figure class="blog-p-img">
              <img class="shimmer lazyload" data-src="/assets/cd4be24f7204cbc1645ff187765fe36f.jpg" src="/assets/cd4be24f7204cbc1645ff187765fe36f.jpg" width="380px" height="285px" alt="Esquadrias de madeira maciça" />
              <span class="blog-cat">Esquadrias de Madeira</span>
            </figure>
            <div class="blog-p-infos">
              <div class="blog-p-data"><i class="las la-calendar-alt"></i>17 de Fevereiro<span></span><i class="las la-clock"></i> 2 min. de leitura</div>
              <div class="blog-p-titulo">Esquadrias de madeira maciça</div>
              <div class="blog-p-texto">A ESEL, empresa especializada em esquadrias de madeira, é referência no mercado desde 1969. Localizada no extremo oeste de Santa Catarina, a ESEL...</div>
              <div class="blog-p-link">Ver postagem <i class="las la-arrow-right"></i></div>
            </div>          
          </a>

          <!-- Post 2 -->
          <a href="/post/uma-nova-linha-um-novo-comeco-ainda-mais-qualidade" class="grid-6 grid-m-6 grid-s-12 blog-p">           
            <figure class="blog-p-img">
              <img class="shimmer lazyload" data-src="/assets/19f1c665239846b0b27b6db70d75b9a8.png" src="/assets/19f1c665239846b0b27b6db70d75b9a8.png" width="380px" height="285px" alt="Uma nova linha, um novo começo, ainda mais qualidade. " />
              <span class="blog-cat">Dicas</span>
            </figure>
            <div class="blog-p-infos">
              <div class="blog-p-data"><i class="las la-calendar-alt"></i>06 de Fevereiro<span></span><i class="las la-clock"></i> 1 min. de leitura</div>
              <div class="blog-p-titulo">Uma nova linha, um novo começo, ainda mais qualidade. </div>
              <div class="blog-p-texto">INDOOR é a nossa mais recente aposta no mercado de portas, trazendo uma proposta inovadora e sofisticada para portas internas. Desenvolvida...</div>
              <div class="blog-p-link">Ver postagem <i class="las la-arrow-right"></i></div>
            </div>          
          </a>

          <!-- Post 3 -->
          <a href="/post/como-a-madeira-pode-transformar-pequenos-ambientes" class="grid-6 grid-m-6 grid-s-12 blog-p">           
            <figure class="blog-p-img">
              <img class="shimmer lazyload" data-src="/assets/d64f4ea92b84ca3a17e5376d340c44bf.png" src="/assets/d64f4ea92b84ca3a17e5376d340c44bf.png" width="380px" height="285px" alt="Como a Madeira Pode Transformar Pequenos Ambientes" />
              <span class="blog-cat">Dicas</span>
            </figure>
            <div class="blog-p-infos">
              <div class="blog-p-data"><i class="las la-calendar-alt"></i>14 de Agosto<span></span><i class="las la-clock"></i> 1 min. de leitura</div>
              <div class="blog-p-titulo">Como a Madeira Pode Transformar Pequenos Ambientes</div>
              <div class="blog-p-texto">A madeira é uma aliada poderosa na decoração de espaços pequenos. Seus tons naturais e texturas trazem aconchego e amplitude...</div>
              <div class="blog-p-link">Ver postagem <i class="las la-arrow-right"></i></div>
            </div>          
          </a>

          <!-- Post 4 -->
          <a href="/post/vantagens-de-usar-madeira-macica-em-espacos-externos" class="grid-6 grid-m-6 grid-s-12 blog-p">           
            <figure class="blog-p-img">
              <img class="shimmer lazyload" data-src="/assets/2f74b222f30cff39fed8c5a256ad128e.jpg" src="/assets/2f74b222f30cff39fed8c5a256ad128e.jpg" width="380px" height="285px" alt="Vantagens de Usar Madeira Maciça em Espaços Externos" />
              <span class="blog-cat">Esquadrias de Madeira</span>
            </figure>
            <div class="blog-p-infos">
              <div class="blog-p-data"><i class="las la-calendar-alt"></i>14 de Agosto<span></span><i class="las la-clock"></i> 1 min. de leitura</div>
              <div class="blog-p-titulo">Vantagens de Usar Madeira Maciça em Espaços Externos</div>
              <div class="blog-p-texto">A madeira maciça é a escolha perfeita para áreas externas, unindo beleza, resistência e durabilidade. Decks, pergolados e...</div>
              <div class="blog-p-link">Ver postagem <i class="las la-arrow-right"></i></div>
            </div>          
          </a>

          <!-- Post 5 -->
          <a href="/post/como-escolher-a-porta-interna-ideal-para-cada-ambiente" class="grid-6 grid-m-6 grid-s-12 blog-p">           
            <figure class="blog-p-img">
              <img class="shimmer lazyload" data-src="/assets/4de92d223d058577122e4230a18caf0c.jpg" src="/assets/4de92d223d058577122e4230a18caf0c.jpg" width="380px" height="285px" alt="Como Escolher a Porta Interna Ideal para Cada Ambiente" />
              <span class="blog-cat">Esquadrias de Madeira</span>
            </figure>
            <div class="blog-p-infos">
              <div class="blog-p-data"><i class="las la-calendar-alt"></i>14 de Agosto<span></span><i class="las la-clock"></i> 1 min. de leitura</div>
              <div class="blog-p-titulo">Como Escolher a Porta Interna Ideal para Cada Ambiente</div>
              <div class="blog-p-texto">Escolher a porta interna certa vai além da estética: ela influencia diretamente no conforto, funcionalidade e estilo do seu espaço. Para...</div>
              <div class="blog-p-link">Ver postagem <i class="las la-arrow-right"></i></div>
            </div>          
          </a>

          <!-- Post 6 -->
          <a href="/post/exporevestir-2025" class="grid-6 grid-m-6 grid-s-12 blog-p">           
            <figure class="blog-p-img">
              <img class="shimmer lazyload" data-src="/assets/bd735c7c8b0fa6956561777b9cb8f926.jpg" src="/assets/bd735c7c8b0fa6956561777b9cb8f926.jpg" width="380px" height="285px" alt="Exporevestir 2025" />
              <span class="blog-cat">Dicas</span>
            </figure>
            <div class="blog-p-infos">
              <div class="blog-p-data"><i class="las la-calendar-alt"></i>25 de Março<span></span><i class="las la-clock"></i> 2 min. de leitura</div>
              <div class="blog-p-titulo">Exporevestir 2025</div>
              <div class="blog-p-texto">Encerramos nossa primeira edição da Exporevestir, e não poderíamos estar mais felizes! Foram cinco dias intensos,...</div>
              <div class="blog-p-link">Ver postagem <i class="las la-arrow-right"></i></div>
            </div>          
          </a>

        </div>
        <!-- //POSTS GRID -->

        <!-- SIDEBAR (DIREITA) -->
        <div class="grid-4 grid-m-12 grid-s-12 side-bar-blog">
          
          <!-- Categorias -->
          <ul class="blog-categorias-btns hide-mobile hide-tablet" data-aos="fade-up">
            <li class="blog-categorias-tit subtitulo">Categorias</li>
            <li><a href="/noticias" class="cat-item cat-item-bd">Todos</a></li>
            <li><a href="#" class="cat-item">Esquadrias de Madeira</a></li>
            <li><a href="#" class="cat-item">Dicas</a></li>
          </ul>
        
          <!-- Recentes -->
          <div class="list-posts-home hide-tablet" data-aos="fade-up">
            <div class="list-blog-post">
              <div class="blog-categorias-tit subtitulo">Posts Recentes</div>

              <!-- Recente 1 -->
              <a href="/post/uma-nova-linha-um-novo-comeco-ainda-mais-qualidade" class="blog-post-side">
                <div class="post-side-img">
                  <img class="shimmer lazyload" data-src="/assets/19f1c665239846b0b27b6db70d75b9a8.png" src="/assets/19f1c665239846b0b27b6db70d75b9a8.png" width="380px" height="285px" alt="Uma nova linha" />
                </div>
                <div>
                  <h3 class="post-side-titulo">Uma nova linha, um novo começo, ainda mais qualidade. </h3>
                  <div class="post-side-date">06 Fev, 2026</div>
                </div>
              </a>

              <!-- Recente 2 -->
              <a href="/post/como-escolher-a-porta-interna-ideal-para-cada-ambiente" class="blog-post-side">
                <div class="post-side-img">
                  <img class="shimmer lazyload" data-src="/assets/4de92d223d058577122e4230a18caf0c.jpg" src="/assets/4de92d223d058577122e4230a18caf0c.jpg" width="380px" height="285px" alt="Porta interna" />
                </div>
                <div>
                  <h3 class="post-side-titulo">Como Escolher a Porta Interna Ideal para Cada Ambiente</h3>
                  <div class="post-side-date">14 Ago, 2025</div>
                </div>
              </a>

              <!-- Recente 3 -->
              <a href="/post/vantagens-de-usar-madeira-macica-em-espacos-externos" class="blog-post-side">
                <div class="post-side-img">
                  <img class="shimmer lazyload" data-src="/assets/2f74b222f30cff39fed8c5a256ad128e.jpg" src="/assets/2f74b222f30cff39fed8c5a256ad128e.jpg" width="380px" height="285px" alt="Madeira maciça" />
                </div>
                <div>
                  <h3 class="post-side-titulo">Vantagens de Usar Madeira Maciça em Espaços Externos</h3>
                  <div class="post-side-date">14 Ago, 2025</div>
                </div>
              </a>

            </div>
          </div>
          <!-- //Recentes -->

        </div>
        <!-- //SIDEBAR -->

      </div>
      <!-- //LISTA -->
      
    </div>
  </section>
  <!-- //PÁGINA -->

  <Footer />
  <Modals />
</Layout>
